# Secrets — never commit API keys
key.cfg
*.key
.env

# Benchmark output is tracked (the specs are hand-authored, not cheaply regenerable);
# ignore only transient run artifacts under it.
/out/**/*.usage.json

# Python / uv
.venv/
__pycache__/
*.pyc

# Bender (compile- or download-to-use; not committed)
/bender/
/bender-x86_64-unknown-linux-gnu/
*.tar.xz
*.tar.xz.sha256
