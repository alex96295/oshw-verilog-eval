#!/usr/bin/env python3
"""Generate natural-language RTL specifications from reference SystemVerilog via an LLM.

Reads a (flattened) reference RTL file and produces a standalone specification document
(Markdown + plain text) describing the module's external behavior, without leaking
implementation details. Backed by litellm, so any provider (openai, anthropic, vertex,
ollama, fireworks, ...) works through the same interface.

Two modes:
  * single : --rtl <file> --top <name> --out <file>
  * batch  : --batch <jsonl>   (each line: {"top": ..., "rtl": ..., "out": ...})

Batch mode runs all designs concurrently (asyncio) under a semaphore, so wall-clock time
is roughly the slowest single design rather than the sum.
"""
import argparse
import asyncio
import json
import os
import re
import sys
from typing import Any, Dict, List, Optional, Tuple

try:
    import litellm
    from litellm import acompletion
except ImportError:  # pragma: no cover - friendly hint
    sys.stderr.write(
        "ERROR: litellm is not installed. Install project deps with `uv sync` "
        "(or `pip install litellm`).\n"
    )
    raise

# litellm is chatty by default; keep our stdout clean for the orchestrator.
litellm.suppress_debug_info = True

EXAMPLE_SPEC = """\
I would like you to implement a module named TopModule with the following
interface. All input and output ports are one bit unless otherwise
specified.

 - input  clk
 - input  in
 - input  reset
 - output out_byte (8 bits)
 - output done

In many (older) serial communications protocols, each data byte is sent
along with a start bit and a stop bit, to help the receiver delimit bytes
from the stream of bits. One common scheme is to use one start bit (0), 8
data bits, and 1 stop bit (1). The line is also at logic 1 when nothing
is being transmitted (idle). Design a finite state machine that will
identify when bytes have been correctly received when given a stream of
bits. It needs to identify the start bit, wait for all 8 data bits, then
verify that the stop bit was correct. The module will also output the
correctly-received data byte. out_byte needs to be valid when done is
1, and is don't-care otherwise. If the stop bit does not appear when
expected, the FSM must wait until it finds a stop bit before attempting
to receive the next byte. Include a active-high synchronous reset. Note
that the serial protocol sends the least significant bit first. It should
assert done each time it finds a stop bit. Assume all sequential logic is
triggered on the positive edge of the clock.
"""

SYSTEM_PROMPT = """
You are an expert hardware specification writer. Produce a clear, standalone
**specification document** for an RTL module **without leaking implementation details**
from any provided reference RTL. The spec must:
- Describe external behavior and interfaces (not the implementation).
- Be detailed and unambiguous (longer specs are fine).
- Avoid code, internal state names, or micro-architecture hints.

Cover:
1) Overview & assumptions.
2) Interface (signals, dir, width, reset/polarity, timing).
3) Protocols/handshakes (valid/ready, AXI/AXI-Lite, req/rsp).
4) Behavioral requirements (corner cases, reset, backpressure, ordering, latency guarantees if applicable, errors).
5) Configuration parameters visible at the boundary (names, ranges, semantics).
6) Throughput/latency expectations at a spec level.
7) Clocking/reset domains and constraints.
8) Example timing/truth tables (no code).

NEVER include implementation specifics gleaned from the RTL (FSM encodings, stage counts, pragmas, internal signal names that aren't externally mandated).
Use the RTL only to infer intent and external requirements. Output Markdown only.
"""

USER_RTL_PROMPT_TEMPLATE = """
Write a **specification document** for a module to be designed, based on the behavior
you can infer from the following reference RTL. The spec must not reveal
implementation details from the reference RTL; treat it only as a hint to understand intent.

Target module name: {target_name}

### Short exemplar spec (style only)
```
{example_spec}
```

### Your task
- Produce a more detailed, production-quality spec than the exemplar.
- Include an interface list with directions, widths, reset polarities, and timing.
- Clearly describe protocols (valid/ready, AXI(-Lite), req/rsp, etc.).
- Clarify configuration parameters & constraints visible at the interface.
- Define behavior on reset, backpressure, invalid/exceptional inputs.
- Avoid micro-architectural/implementation-specific guidance.
- Do not include a title for the specification document.

### Provided Reference RTL
```systemverilog
{rtl_text}
```

Return only the final specification in Markdown. Do not include code.

[NAMING CONVENTION]

1. In the specification you generate, you must name the top level to be
designed "TopModule". So never mention the specific name of the module you read
from the reference RTL.
2. Always introduce the spec with "Design a module called TopModule. This
module [...]". This way, the RTL designer (human or AI-based) knows exactly how
to call the module. In the remainder, you describe what the module does
(specifications), and when you refer to it, you always call it "TopModule".
"""

# --- Optional quality/leakage review pass ---------------------------------------------

REVIEW_SYSTEM_PROMPT = """
You are a meticulous reviewer of hardware specification documents. You are given the
reference RTL a spec was derived from, and the spec itself. Judge the spec on two axes:

1) LEAKAGE: the spec must NOT reveal implementation details from the RTL — no internal
   signal names, FSM state encodings, pipeline/stage counts, pragmas, or micro-architecture.
   It should describe only externally observable behavior and the interface.
2) COMPLETENESS: the spec must cover the full external interface (every port and
   boundary-visible parameter) and the key behavior (reset, protocols/handshakes,
   corner cases).

Respond with STRICT JSON only (no prose, no backticks):
{"ok": <true|false>, "issues": ["<short actionable issue>", ...]}
Set "ok" to true only if there is no leakage AND the interface/behavior coverage is adequate.
Keep each issue short and actionable. If ok is true, "issues" may be an empty list.
"""

REVIEW_USER_TEMPLATE = """
### Reference RTL
```systemverilog
{rtl_text}
```

### Candidate specification
{spec_md}

Review the specification per the rules and return the STRICT JSON verdict.
"""

# ------------------------------------------------------------------------------------
# Provider / key handling
# ------------------------------------------------------------------------------------

# Map our short provider names onto litellm's model-id prefixes.
_PROVIDER_ALIASES = {
    "vertex": "vertex_ai",
    "fireworks": "fireworks_ai",
}


def load_key_cfg(path: str) -> None:
    """Load a key.cfg file (lines like `OPENAI_API_KEY = 'xxx'`) into os.environ.

    Existing environment variables take precedence, so an already-exported key is not
    overwritten. Missing file is not an error (env vars alone may suffice).
    """
    if not path or not os.path.isfile(path):
        return
    with open(path, "r", encoding="utf-8") as f:
        for raw in f:
            line = raw.strip()
            if not line or line.startswith("#") or "=" not in line:
                continue
            key, _, val = line.partition("=")
            key = key.strip()
            val = val.strip().strip("'").strip('"').strip()
            if key and val and key not in os.environ:
                os.environ[key] = val
    # Convenience mapping for Vertex AI so the README's key.cfg keys keep working.
    if "VERTEX_SERVICE_ACCOUNT_PATH" in os.environ and "GOOGLE_APPLICATION_CREDENTIALS" not in os.environ:
        os.environ["GOOGLE_APPLICATION_CREDENTIALS"] = os.environ["VERTEX_SERVICE_ACCOUNT_PATH"]
    if "VERTEX_REGION" in os.environ and "VERTEXAI_LOCATION" not in os.environ:
        os.environ["VERTEXAI_LOCATION"] = os.environ["VERTEX_REGION"]


def resolve_model_id(provider: str, model: str) -> str:
    """Build a litellm model id like `openai/gpt-4o` from provider + model.

    If `model` already carries a provider prefix, it is returned unchanged.
    """
    if "/" in model or not provider:
        return model
    prefix = _PROVIDER_ALIASES.get(provider.lower(), provider.lower())
    return f"{prefix}/{model}"


# ------------------------------------------------------------------------------------
# Text utilities
# ------------------------------------------------------------------------------------

def count_tokens(model_id: str, text: str) -> int:
    """Best-effort token count via litellm; falls back to a rough chars/4 estimate."""
    try:
        return litellm.token_counter(model=model_id, text=text)
    except Exception:
        return max(1, len(text) // 4)


def soft_trim(model_id: str, parts: List[Tuple[str, int]], budget: int) -> List[str]:
    """Greedily trims the longest part by ~10% until within budget; each part keeps a reserve."""
    import math
    ss = [p for p, _ in parts]
    rs = [r for _, r in parts]
    cnts = [count_tokens(model_id, s) for s in ss]
    if sum(cnts) <= budget:
        return ss
    MINC = 128
    while sum(cnts) > budget:
        i = max(range(len(cnts)), key=lambda k: cnts[k])
        floor = max(rs[i], MINC)
        if all(c <= max(r, MINC) for c, r in zip(cnts, rs)):
            break
        if cnts[i] <= floor:
            cands = [k for k, c in enumerate(cnts) if c > max(rs[k], MINC)]
            if not cands:
                break
            i = max(cands, key=lambda k: cnts[k])
        new_len = max(floor, int(math.floor(cnts[i] * 0.9)))
        ratio = new_len / max(cnts[i], 1)
        cut = max(1, int(len(ss[i]) * ratio))
        ss[i] = ss[i][:cut]
        cnts[i] = count_tokens(model_id, ss[i])
    return ss


def md_to_txt(md: str) -> str:
    """Tiny Markdown -> plain text cleaner (safe for LLM ingestion)."""
    txt = md
    # strip fenced code blocks (keep their inner text)
    txt = re.sub(r"```[\s\S]*?```",
                 lambda m: re.sub(r"^```.*\n|\n```$", "", m.group(0), flags=re.M),
                 txt)
    # headers, emphasis (keep underscores)
    txt = re.sub(r"^#{1,6}\s*", "", txt, flags=re.M)
    txt = txt.replace("**", "").replace("*", "")
    # inline code
    txt = txt.replace("`", "")
    # links: [text](url) -> text (url)
    txt = re.sub(r"\[([^\]]+)\]\(([^)]+)\)", r"\1 (\2)", txt)
    # tables & blockquotes
    txt = txt.replace("|", " ")
    txt = re.sub(r"^\s*>\s?", "", txt, flags=re.M)
    # collapse blank lines
    txt = re.sub(r"\n{3,}", "\n\n", txt).strip()
    return txt


def _read(path: str) -> str:
    with open(path, "r", encoding="utf-8", errors="replace") as f:
        return f.read()


def _usage_tokens(resp: Any) -> Tuple[int, int]:
    """Extract (in_tokens, out_tokens) from a litellm response, tolerant of shape."""
    try:
        u = resp.usage
        return int(getattr(u, "prompt_tokens", 0) or 0), int(getattr(u, "completion_tokens", 0) or 0)
    except Exception:
        return 0, 0


def _content(resp: Any) -> str:
    try:
        return (resp.choices[0].message.content or "").strip()
    except Exception:
        return ""


# ------------------------------------------------------------------------------------
# Core generation (async)
# ------------------------------------------------------------------------------------

class SpecConfig:
    """Shared, immutable LLM/config for all designs in a run."""

    def __init__(self, provider: str, model: str, max_token: int, tokens: int,
                 temperature: float, top_p: float, review: bool):
        self.provider = provider
        self.model = model
        self.model_id = resolve_model_id(provider, model)
        self.max_token = max_token
        self.tokens = tokens
        self.temperature = temperature
        self.top_p = top_p
        self.review = review

    async def _chat(self, messages: List[Dict[str, str]]) -> Any:
        return await acompletion(
            model=self.model_id,
            messages=messages,
            temperature=self.temperature,
            top_p=self.top_p,
            max_tokens=self.max_token,
        )


def _build_spec_messages(cfg: SpecConfig, top: str, rtl_txt: str,
                         extra_feedback: Optional[str] = None) -> List[Dict[str, str]]:
    user_raw = USER_RTL_PROMPT_TEMPLATE.format(
        target_name=top, example_spec=EXAMPLE_SPEC, rtl_text="{{RTL_PLACEHOLDER}}"
    )
    static = user_raw.replace("{{RTL_PLACEHOLDER}}", "")
    reserve = 3000
    rem = max(cfg.tokens - reserve, 2000)
    trimmed = soft_trim(cfg.model_id, [(static, 2000), (rtl_txt, rem)], cfg.tokens)
    user_final = user_raw.replace("{{RTL_PLACEHOLDER}}", trimmed[1])
    if extra_feedback:
        user_final += (
            "\n\n[REVISION REQUESTED]\nA reviewer found the following issues with a "
            "previous draft. Fix all of them in this revision:\n" + extra_feedback
        )
    return [
        {"role": "system", "content": SYSTEM_PROMPT},
        {"role": "user", "content": user_final},
    ]


async def _review_spec(cfg: SpecConfig, rtl_txt: str, spec_md: str) -> Tuple[bool, List[str], Tuple[int, int]]:
    """Run the leakage/completeness review pass. Returns (ok, issues, (in_tok, out_tok))."""
    # Trim RTL to keep the review prompt within budget too.
    trimmed = soft_trim(cfg.model_id, [(spec_md, 4000), (rtl_txt, max(cfg.tokens - 6000, 2000))], cfg.tokens)
    messages = [
        {"role": "system", "content": REVIEW_SYSTEM_PROMPT},
        {"role": "user", "content": REVIEW_USER_TEMPLATE.format(rtl_text=trimmed[1], spec_md=trimmed[0])},
    ]
    resp = await cfg._chat(messages)
    it, ot = _usage_tokens(resp)
    raw = _content(resp)
    # Be forgiving: extract the first JSON object if the model wrapped it.
    m = re.search(r"\{[\s\S]*\}", raw)
    if m:
        raw = m.group(0)
    try:
        verdict = json.loads(raw)
        ok = bool(verdict.get("ok", False))
        issues = [str(x) for x in verdict.get("issues", []) if str(x).strip()]
        return ok, issues, (it, ot)
    except Exception:
        # If the reviewer misbehaves, don't block generation — accept the spec.
        return True, [], (it, ot)


async def generate_spec(cfg: SpecConfig, top: str, rtl_path: str, out_base: str,
                        sem: asyncio.Semaphore) -> Dict[str, Any]:
    """Generate spec .md/.txt for one design. Returns a result/usage record."""
    out_dir = os.path.dirname(os.path.abspath(out_base)) or "."
    base = os.path.splitext(os.path.basename(out_base))[0]
    out_md = os.path.join(out_dir, base + ".md")
    out_txt = os.path.join(out_dir, base + ".txt")

    result: Dict[str, Any] = {"top": top, "rtl": rtl_path, "md": out_md, "txt": out_txt,
                              "ok": False, "in_tokens": 0, "out_tokens": 0}
    async with sem:
        try:
            if not os.path.isfile(rtl_path):
                raise FileNotFoundError(f"RTL file not found: {rtl_path}")
            rtl_txt = _read(rtl_path)
            os.makedirs(out_dir, exist_ok=True)

            in_tok = out_tok = 0

            # First draft.
            resp = await cfg._chat(_build_spec_messages(cfg, top, rtl_txt))
            spec_md = _content(resp)
            it, ot = _usage_tokens(resp)
            in_tok += it
            out_tok += ot

            # Optional review + single regeneration.
            if cfg.review and spec_md:
                ok, issues, (rit, rot) = await _review_spec(cfg, rtl_txt, spec_md)
                in_tok += rit
                out_tok += rot
                if not ok and issues:
                    resp2 = await cfg._chat(
                        _build_spec_messages(cfg, top, rtl_txt, extra_feedback="\n".join(f"- {i}" for i in issues))
                    )
                    revised = _content(resp2)
                    it2, ot2 = _usage_tokens(resp2)
                    in_tok += it2
                    out_tok += ot2
                    if revised:
                        spec_md = revised

            if not spec_md:
                raise RuntimeError("LLM returned an empty specification")

            with open(out_md, "w", encoding="utf-8") as f:
                f.write(spec_md + ("" if spec_md.endswith("\n") else "\n"))
            spec_txt = md_to_txt(spec_md)
            with open(out_txt, "w", encoding="utf-8") as f:
                f.write(spec_txt + ("" if spec_txt.endswith("\n") else "\n"))

            result.update(ok=True, in_tokens=in_tok, out_tokens=out_tok)
        except Exception as e:  # per-design isolation
            result["error"] = f"{type(e).__name__}: {e}"
        return result


def _write_usage(out_base: str, cfg: SpecConfig, records: List[Dict[str, Any]]) -> None:
    """Write a .usage.json next to the (first) output base with aggregate stats."""
    in_tok = sum(r.get("in_tokens", 0) for r in records)
    out_tok = sum(r.get("out_tokens", 0) for r in records)
    stats: Dict[str, Any] = {
        "model": cfg.model_id,
        "provider": cfg.provider,
        "designs": len(records),
        "ok": sum(1 for r in records if r.get("ok")),
        "failed": sum(1 for r in records if not r.get("ok")),
        "in_tokens": in_tok,
        "out_tokens": out_tok,
    }
    try:
        cost = litellm.cost_per_token(model=cfg.model_id, prompt_tokens=in_tok, completion_tokens=out_tok)
        stats["estimated_usd"] = round(sum(cost), 6)
    except Exception:
        pass
    usage_path = os.path.splitext(out_base)[0] + ".usage.json"
    with open(usage_path, "w", encoding="utf-8") as f:
        json.dump(stats, f, indent=2)


# ------------------------------------------------------------------------------------
# Entry points
# ------------------------------------------------------------------------------------

async def _run(cfg: SpecConfig, designs: List[Dict[str, str]], concurrency: int) -> List[Dict[str, Any]]:
    sem = asyncio.Semaphore(max(1, concurrency))
    tasks = [generate_spec(cfg, d["top"], d["rtl"], d["out"], sem) for d in designs]
    return await asyncio.gather(*tasks)


def _load_batch(path: str) -> List[Dict[str, str]]:
    designs: List[Dict[str, str]] = []
    with open(path, "r", encoding="utf-8") as f:
        for ln, raw in enumerate(f, 1):
            raw = raw.strip()
            if not raw:
                continue
            obj = json.loads(raw)
            for k in ("top", "rtl", "out"):
                if k not in obj:
                    raise ValueError(f"{path}:{ln}: batch entry missing '{k}'")
            designs.append({"top": obj["top"], "rtl": obj["rtl"], "out": obj["out"]})
    return designs


def main() -> int:
    ap = argparse.ArgumentParser(
        description="Generate an RTL specification (Markdown + text) from reference RTL via an LLM."
    )
    ap.add_argument("--rtl", help="Path to the reference RTL file (single mode)")
    ap.add_argument("--top", help="Top-level module name (single mode)")
    ap.add_argument("--out", default="spec.md", help="Output base filename (single mode; default: spec.md)")
    ap.add_argument("--batch", help="Path to a JSONL worklist ({top,rtl,out} per line); enables batch mode")
    ap.add_argument("--concurrency", type=int, default=8, help="Max concurrent LLM requests (default: 8)")
    ap.add_argument("--provider", default="openai", help="LLM provider (openai, anthropic, vertex, ollama, ...)")
    ap.add_argument("--model", default="gpt-4o-2024-08-06", help="LLM model name")
    ap.add_argument("--key-cfg", "--key-cfg-path", dest="key_cfg", default="./key.cfg",
                    help="Path to API keys configuration file")
    ap.add_argument("--max-token", type=int, default=8192, help="Maximum tokens per LLM response")
    ap.add_argument("--tokens", type=int, default=12000, help="Total token budget for prompt+inputs")
    ap.add_argument("--temperature", type=float, default=0.85, help="LLM sampling temperature")
    ap.add_argument("--top-p", type=float, default=0.95, help="LLM nucleus sampling parameter")
    review = ap.add_mutually_exclusive_group()
    review.add_argument("--review", dest="review", action="store_true", default=True,
                        help="Run the leakage/completeness review pass (default: on)")
    review.add_argument("--no-review", dest="review", action="store_false",
                        help="Disable the review pass")
    args = ap.parse_args()

    load_key_cfg(args.key_cfg)

    cfg = SpecConfig(
        provider=args.provider, model=args.model, max_token=args.max_token, tokens=args.tokens,
        temperature=args.temperature, top_p=args.top_p, review=args.review,
    )

    if args.batch:
        designs = _load_batch(args.batch)
        out_base = designs[0]["out"] if designs else args.out
    else:
        if not args.rtl or not args.top:
            ap.error("single mode requires --rtl and --top (or use --batch)")
        designs = [{"top": args.top, "rtl": args.rtl, "out": args.out}]
        out_base = args.out

    if not designs:
        sys.stderr.write("No designs to process.\n")
        return 0

    records = asyncio.run(_run(cfg, designs, args.concurrency))
    _write_usage(out_base, cfg, records)

    ok = [r for r in records if r.get("ok")]
    failed = [r for r in records if not r.get("ok")]
    for r in failed:
        sys.stderr.write(f"[spec-gen] FAILED {r['top']} ({r['rtl']}): {r.get('error')}\n")
    sys.stderr.write(f"[spec-gen] {len(ok)} ok / {len(failed)} failed "
                     f"({sum(r.get('in_tokens', 0) for r in records)} in, "
                     f"{sum(r.get('out_tokens', 0) for r in records)} out tokens)\n")
    return 1 if failed else 0


if __name__ == "__main__":
    sys.exit(main())
